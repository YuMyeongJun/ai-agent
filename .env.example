# Claude API (없거나 크레딧 부족 시 로컬 Mock으로 동작)
ANTHROPIC_API_KEY=sk-ant-...

# API 키가 있어도 Mock 강제 (1=true)
# CLAUDE_FORCE_MOCK=1

# 모델 (선택)
CLAUDE_MODEL=claude-sonnet-4-20250514

# 백엔드 포트
BACKEND_PORT=8000

# Claude Design 웹 (디자이너 산출물 — claude.ai/design 링크)
CLAUDE_DESIGN_URL=https://claude.ai/design

# Figma API (선택 — 기본 디자이너 경로는 Claude Design)
# FIGMA_ACCESS_TOKEN=
# FIGMA_FILE_KEY=
# FIGMA_EXPORT_NODE_IDS=
